# Copy this file to .env and fill in your Binance Futures Testnet API credentials.
# Get these from https://testnet.binancefuture.com after registering/activating
# a Futures Testnet account and generating an API key.

BINANCE_TESTNET_API_KEY=your_api_key_here
BINANCE_TESTNET_API_SECRET=your_api_secret_here
